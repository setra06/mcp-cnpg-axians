{
  "name": "@setra06/mcp-cnpg-axians",
  "version": "3.6.0",
  "type": "module",
  "description": "MCP server for CloudNativePG (CNPG 1.24+/1.29). 53 tools covering cluster lifecycle, backups & restore, declarative Database/Publication/Subscription CRDs, ImageCatalog upgrades, PgBouncer pooler, hibernation, switchover/promote, and observability.",
  "main": "dist/index.js",
  "bin": {
    "mcp-cnpg-axians": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test:smoke": "tsx test/smoke.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "mcp",
    "kubernetes",
    "cnpg",
    "postgresql",
    "claude",
    "model-context-protocol",
    "anthropic",
    "axians",
    "backup",
    "restore",
    "high-availability",
    "replication",
    "pgbouncer",
    "connection-pooling",
    "database-management",
    "devops"
  ],
  "author": "Anthony Macle <anthony.macle@axians.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/setra06/mcp-cnpg-axians.git"
  },
  "homepage": "https://github.com/setra06/mcp-cnpg-axians#readme",
  "bugs": {
    "url": "https://github.com/setra06/mcp-cnpg-axians/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "package.json",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
